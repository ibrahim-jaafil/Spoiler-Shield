{
    "manifest_version":3,
    "name":"Spoiler Shield",
    "version":"1.0",
    "description":"an extension that blocks spoilers on websites",

    "action":{
        "default_popup":"spoiler-shield/ui/popup.html"
    },
    "permissions":[
        "storage",
        "activeTab",
        "scripting"
    ],
    "content_scripts":[
        {
            "matches":["<all_urls>"],
            "js":["spoiler-shield/content.js"]
        }
    ]

}

